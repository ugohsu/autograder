# このファイルを .env にコピーして使ってください: cp .env.example .env

# Flaskのセッション署名鍵。適当な文字列に変更してください
# （例: python3 -c "import secrets; print(secrets.token_hex(32))"）
SECRET_KEY=please-change-this-secret-key

# コンテナをこのUID/GIDで実行します。./data 配下に作られるファイルがこのユーザー
# 所有になるようにするためのものです（rootで作られると後で削除できなくなります）。
# ターミナルで `id -u` と `id -g` を実行して、出てきた数字に置き換えてください。
# 分からなければそのままでも大抵は動きます（Linux/WSL2の最初のユーザーは通常1000）。
APP_UID=1000
APP_GID=1000
